# CyberSentinel — set ONE AI provider key (Gemini is free, Anthropic is paid)

# ─── FREE: Google Gemini 2.5 Flash Lite ──────────────────────────────────────
# Get key at: https://aistudio.google.com/app/apikey
# Free tier: 20 requests/day — create a new project for a fresh quota
GEMINI_API_KEY=your_gemini_api_key_here

# ─── PAID: Anthropic Claude claude-sonnet-4-6 ────────────────────────────────
# Get key at: https://console.anthropic.com
# Better quality — pay per use (~$0.01 per investigation)
# If BOTH keys are set, Anthropic takes priority.
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# VirusTotal free tier: https://www.virustotal.com/gui/join-us
# If not set, VirusTotal checks are skipped (investigation still works)
# VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# ─── Flask settings ───────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false
