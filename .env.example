# Required: Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: VirusTotal API Key (free tier at https://www.virustotal.com)
# If not set, VirusTotal checks will be skipped gracefully
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Optional: Flask settings
FLASK_DEBUG=false
FLASK_PORT=5000
