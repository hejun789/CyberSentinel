# ─── AI Provider (set ONE of these) ─────────────────────────────────────────

# FREE option — Google Gemini 1.5 Flash (1500 req/day, no billing required)
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Paid option — Anthropic Claude (best quality, requires API credits)
# Get key at: https://console.anthropic.com
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# If BOTH are set, Anthropic takes priority.

# ─── Optional ────────────────────────────────────────────────────────────────

# VirusTotal (free tier at https://www.virustotal.com/gui/join-us)
# VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Flask settings
FLASK_PORT=5000
FLASK_DEBUG=false
